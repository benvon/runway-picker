{
  "name": "runway-picker-metar-api",
  "main": "src/index.ts",
  "workers_dev": false,
  "compatibility_date": "2026-03-02",
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "vars": {
    "APP_ENV": "production",
    "ENABLE_DEBUG_ERRORS": "false",
    "CACHE_REFRESH_ENABLED": "true",
    "CACHE_REFRESH_METAR_INTERVAL_SECONDS": "1800",
    "CACHE_REFRESH_AIRPORT_INTERVAL_SECONDS": "86400",
    "CACHE_REFRESH_INACTIVITY_TTL_SECONDS": "432000",
    "CACHE_REFRESH_MAX_ITEMS_PER_RUN": "25"
  },
  "kv_namespaces": [
    {
      "binding": "METAR_CACHE",
      "id": "98b4d5d8e9f44e8cb3396e4cefbce840"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "CACHE_COORDINATOR",
        "class_name": "CacheSingleFlightCoordinator"
      },
      {
        "name": "API_RATE_LIMITER",
        "class_name": "ApiRateLimiter"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1-cache-coordinator",
      "new_sqlite_classes": ["CacheSingleFlightCoordinator"]
    },
    {
      "tag": "v2-api-rate-limiter",
      "new_sqlite_classes": ["ApiRateLimiter"]
    }
  ],
  "env": {
    "preview": {
      "vars": {
        "APP_ENV": "preview",
        "ENABLE_DEBUG_ERRORS": "true",
        "CACHE_REFRESH_ENABLED": "true",
        "CACHE_REFRESH_METAR_INTERVAL_SECONDS": "1800",
        "CACHE_REFRESH_AIRPORT_INTERVAL_SECONDS": "86400",
        "CACHE_REFRESH_INACTIVITY_TTL_SECONDS": "432000",
        "CACHE_REFRESH_MAX_ITEMS_PER_RUN": "25"
      },
      "kv_namespaces": [
        {
          "binding": "METAR_CACHE"
        }
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "CACHE_COORDINATOR",
            "class_name": "CacheSingleFlightCoordinator"
          },
          {
            "name": "API_RATE_LIMITER",
            "class_name": "ApiRateLimiter"
          }
        ]
      }
    }
  }
}
