{
  "name": "runway-picker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Simple web app to help you choose which runway to use.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild-inline-css.mjs && node scripts/verify-build-artifacts.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:complexity:report": "eslint src workers functions scripts --ignore-pattern '**/*.test.ts' --ignore-pattern 'src/test/**' --rule 'complexity:[\"warn\",12]'",
    "lint:workflows": "node scripts/lint-workflows.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "quality:report": "npm run test:coverage && npm run lint:complexity:report",
    "test:e2e": "playwright test",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "security:audit": "node scripts/run-audit.mjs",
    "security": "npm run security:secrets && npm run lint:workflows && npm run security:audit",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage && npm run build && npm run security",
    "ci:e2e": "npm run test:e2e",
    "cf:typegen": "wrangler types --path='./functions/types.d.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benvon/runway-picker.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/benvon/runway-picker/issues"
  },
  "homepage": "https://github.com/benvon/runway-picker#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  }
}
